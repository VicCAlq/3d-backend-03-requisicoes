{
  "name": "Atividade",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "start": "node ./src/app.js",
    "dev": "nodemon ./src/app.js",
    "vite": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --reporter=json --output-file=./resultado.json",
    "tr": "timeout --signal=SIGKILL 5s npx vitest run --reporter=json --output-file=./resultado.json --pool=forks --testTimeout=5000 || true",
    "th": "vitest --help",
    "trh": "vitest run --help"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "express": "^5.2.1"
  }
}
